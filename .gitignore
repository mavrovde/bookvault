# Secrets and local per-user state -- never commit these.
.env
.litres_session.json
.litres_cache.json
.litres_state.json

# Python runtime / build artifacts
.venv/
__pycache__/
*.pyc
*.egg
*.egg-info/
build/
dist/

# Tooling caches and coverage output
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Desktop build artifacts (PyInstaller / installers)
packaging/*/build/
packaging/*/dist/

# IDE and editor directories
.idea/
.vscode/
*.iml
*.iws
*.ipr

# Bob (AI assistant) config and scratch directories
.claude/
.bob/
